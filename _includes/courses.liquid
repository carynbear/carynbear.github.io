{% if site.teachings %}
  <div class="courses">
    {% assign courses = site.teachings | sort: 'year' | reverse | sort: 'term' %}
    <div class="course-list">
      {% for course in courses %}
        <div class="course-item">
          <h3 class="course-title">
            <a href="{{ course.url | relative_url }}">
              {% if course.course_code %}
                {{ course.course_code }}:
              {% elsif course.code %}
                {{ course.code }}:
              {% endif %}
              {{ course.title }}
            </a>
          </h3>

          <div class="course-meta">
            {% if course.location %}
              <span class="course-school">{{ course.location }}</span>
            {% endif %}

            {% if course.year %}
              <span class="course-year">{{ course.year }}</span>
            {% endif %}

            {% if course.term %}
              <span class="course-term">{{ course.term }}</span>
            {% endif %}
          </div>

          {% if course.position %}
            <div class="course-position">{{ course.position }}</div>
          {% endif %}

          {% if course.description %}
            <div class="course-description">
              {{ course.description | markdownify }}
            </div>
          {% endif %}

          {% if course.links %}
            <div class="course-links mt-2">
              <small>
                {% for link in course.links %}
                  {% if link.url contains '://' %}
                    <a href="{{ link.url }}" target="_blank" rel="noopener noreferrer">{{ link.label }}</a>
                  {% else %}
                    <a href="{{ link.url | relative_url }}">{{ link.label }}</a>
                  {% endif %}
                  {% unless forloop.last %} · {% endunless %}
                {% endfor %}
              </small>
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
{% else %}
  <p>No courses available yet.</p>
{% endif %}
